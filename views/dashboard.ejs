<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AeroMiles - Dashboard</title>
    <link rel="stylesheet" href="/style.css"> </head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <div class="card">
            <h2>Selamat Datang, <%= user.name %>!</h2>
            <p style="text-align: center; color: #666;">NPM: <%= user.npm %></p>
            
            <div class="balance-box">
                <h3>TOTAL SALDO MILES</h3>
                <div class="miles"><%= user.miles %> <span style="font-size: 1rem;">PTS</span></div>
                <p>Status Keanggotaan: <strong>Blue Tier</strong></p>
            </div>

            <h3>Aktivitas Terakhir</h3>
            <div class="info-row">
                <span>Penerbangan CGK-DPS</span>
                <span style="color: green;">+500 pts</span>
            </div>
        </div>
    </div>
</body>
</html>