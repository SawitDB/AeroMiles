<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrasi - AeroMiles</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body style="display: flex; align-items: center; justify-content: center; height: 100vh;">
    <div class="card" style="width: 400px;">
        <h2>AEROMILES</h2>
        <p style="text-align: center; margin-bottom: 20px;">Buat Akun Member Baru</p>
        
        <form action="/register" method="POST">
            <div class="form-group">
                <label>Nama Lengkap (Sesuai KTP/Paspor)</label>
                <input type="text" name="name" placeholder="Masukkan nama lengkap" required>
            </div>
            
            <div class="form-group">
                <label>Nomor Telepon / Email</label>
                <input type="text" name="contact" placeholder="Masukkan kontak aktif" required>
            </div>
            
            <div class="form-group">
                <label>Username</label>
                <input type="text" name="username" placeholder="Buat username" required>
            </div>
            
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="Buat password" required>
            </div>
            
            <button type="submit">DAFTAR MEMBER SEKARANG</button>
        </form>
        
        <p style="text-align: center; margin-top: 15px; font-size: 0.9rem;">
            Sudah punya akun member? <a href="/login" style="color: var(--primary-blue); font-weight: bold;">Masuk di sini</a>
        </p>
    </div>
</body>
</html>